              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bncc.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const response = pm.response.json();",
                    "    pm.collectionVariables.set('token', response.accessToken);",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
