            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"admin\",\n  \"email\": \"admin@bncc.com\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
